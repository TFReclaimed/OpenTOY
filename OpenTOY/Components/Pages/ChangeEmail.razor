@page "/change-email"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using OpenTOY.Options
@using OpenTOY.Services
@inject IAccountService AccountService
@inject IOptions<ServiceOptions> ServiceOptions

<PageTitle>Change Email | OpenTOY</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="3">
        <MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.h5" Align="Align.Center">
                    Change Your Email
                </MudText>
            </MudCardContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    @ErrorMessage
                </MudAlert>
            }

            @if (Success)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Email changed successfully.
                </MudAlert>
            }

            <EditForm Model="Model" OnValidSubmit="HandleChangeEmail" FormName="ChangeEmailForm">
                <DataAnnotationsValidator/>

                <MudStaticRadioGroup
                    @bind-Value="Model!.ServiceId"
                    For="() => Model!.ServiceId"
                    Required="true"
                    InputClass="d-flex flex-column">
                    @foreach (var (id, serviceInfo) in ServiceOptions.Value.Services)
                    {
                        <MudStaticRadio
                            Value="@id"
                            Label="@serviceInfo.Title"/>
                    }
                </MudStaticRadioGroup>

                <MudStaticTextField
                    @bind-Value="Model!.CurrentEmail"
                    For="() => Model!.CurrentEmail"
                    Label="Current Email"
                    Required="true"
                    InputType="InputType.Email"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticTextField
                    @bind-Value="Model!.Password"
                    For="() => Model!.Password"
                    Label="Current Password"
                    Required="true"
                    InputType="InputType.Password"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticTextField
                    @bind-Value="Model!.NewEmail"
                    For="() => Model!.NewEmail"
                    Label="New Email"
                    Required="true"
                    InputType="InputType.Email"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    FullWidth="true"
                    Class="mt-4"
                    StartIcon="@Icons.Material.Filled.Save">
                    Change Email
                </MudStaticButton>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {

    [SupplyParameterFromForm]
    private ChangeEmailModel? Model { get; set; }

    private string? ErrorMessage { get; set; }

    private bool Success { get; set; }

    protected override void OnInitialized()
    {
        Model ??= new ChangeEmailModel();
    }

    private async Task HandleChangeEmail()
    {
        ErrorMessage = null;
        Success = false;
        if (Model == null)
        {
            return;
        }

        if (!AccountService.IsValidEmail(Model.NewEmail))
        {
            ErrorMessage = "The new email address is not valid.";
            return;
        }

        var serviceId = int.TryParse(Model.ServiceId, out var id) ? id : 0;
        var (user, error) = await AccountService.SignInAsync(serviceId, Model.CurrentEmail, Model.Password);
        if (user == null)
        {
            ErrorMessage = error;
            return;
        }

        var result = await AccountService.ChangeEmailAsync(serviceId, Model.CurrentEmail, Model.NewEmail);
        if (result)
        {
            Success = true;
        }
        else
        {
            ErrorMessage = "Failed to change email. Please try again.";
        }
    }

    public class ChangeEmailModel
    {
        [Required(ErrorMessage = "Service ID is required.")]
        public string ServiceId { get; set; } = string.Empty;

        [Required(ErrorMessage = "Current email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string CurrentEmail { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "New email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string NewEmail { get; set; } = string.Empty;
    }

}