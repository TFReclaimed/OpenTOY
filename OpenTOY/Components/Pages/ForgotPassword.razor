@page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using OpenTOY.Options
@using OpenTOY.Services
@inject IAccountService AccountService
@inject IOptions<ServiceOptions> ServiceOptions

<PageTitle>Forgot Password | OpenTOY</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="3">
        <MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.h5" Align="Align.Center">
                    Forgot Your Password?
                </MudText>
            </MudCardContent>
        </MudCardHeader>
        <MudCardContent>
            @if (Sent)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    If an account with that email exists, a password reset link has been sent.
                </MudAlert>
            }

            <EditForm Model="Model" OnValidSubmit="HandleForgotPassword" FormName="ForgotPasswordForm">
                <DataAnnotationsValidator/>

                <MudStaticRadioGroup
                    @bind-Value="Model!.ServiceId"
                    For="() => Model!.ServiceId"
                    Required="true"
                    InputClass="d-flex flex-column">
                    @foreach (var (id, serviceInfo) in ServiceOptions.Value.Services)
                    {
                        <MudStaticRadio
                            Value="@id"
                            Label="@serviceInfo.Title"/>
                    }
                </MudStaticRadioGroup>

                <MudStaticTextField
                    @bind-Value="Model!.Email"
                    For="() => Model!.Email"
                    Label="Email"
                    Required="true"
                    InputType="InputType.Email"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    FullWidth="true"
                    Class="mt-4"
                    StartIcon="@Icons.Material.Filled.Email">
                    Send Reset Link
                </MudStaticButton>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {

    [SupplyParameterFromForm]
    private ForgotPasswordModel? Model { get; set; }

    private bool Sent { get; set; }

    protected override void OnInitialized()
    {
        Model ??= new ForgotPasswordModel();
    }

    private async Task HandleForgotPassword()
    {
        Sent = false;
        if (Model == null)
        {
            return;
        }

        var serviceId = int.TryParse(Model.ServiceId, out var id) ? id : 0;
        await AccountService.SendPasswordResetEmailAsync(serviceId, Model.Email);
        Sent = true;
    }

    public class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Service ID is required.")]
        public string ServiceId { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;
    }

}