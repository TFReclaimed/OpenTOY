@page "/change-password"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using OpenTOY.Options
@using OpenTOY.Services
@inject IAccountService AccountService
@inject IOptions<ServiceOptions> ServiceOptions

<PageTitle>Change Password | OpenTOY</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="3">
        <MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.h5" Align="Align.Center">
                    Change Your Password
                </MudText>
            </MudCardContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    @ErrorMessage
                </MudAlert>
            }

            @if (Success)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Password changed successfully.
                </MudAlert>
            }

            <EditForm Model="Model" OnValidSubmit="HandleChangePassword" FormName="ChangePasswordForm">
                <DataAnnotationsValidator/>

                <MudStaticRadioGroup
                    @bind-Value="Model!.ServiceId"
                    For="() => Model!.ServiceId"
                    Required="true"
                    InputClass="d-flex flex-column">
                    @foreach (var (id, serviceInfo) in ServiceOptions.Value.Services)
                    {
                        <MudStaticRadio
                            Value="@id"
                            Label="@serviceInfo.Title"/>
                    }
                </MudStaticRadioGroup>

                <MudStaticTextField
                    @bind-Value="Model!.Email"
                    For="() => Model!.Email"
                    Label="Email"
                    Required="true"
                    InputType="InputType.Email"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticTextField
                    @bind-Value="Model!.CurrentPassword"
                    For="() => Model!.CurrentPassword"
                    Label="Current Password"
                    Required="true"
                    InputType="InputType.Password"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticTextField
                    @bind-Value="Model!.NewPassword"
                    For="() => Model!.NewPassword"
                    Label="New Password"
                    Required="true"
                    InputType="InputType.Password"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticTextField
                    @bind-Value="Model!.ConfirmNewPassword"
                    For="() => Model!.ConfirmNewPassword"
                    Label="Confirm New Password"
                    Required="true"
                    InputType="InputType.Password"
                    Variant="Variant.Outlined"
                    Margin="Margin.Normal"/>

                <MudStaticButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    FullWidth="true"
                    Class="mt-4"
                    StartIcon="@Icons.Material.Filled.Save">
                    Change Password
                </MudStaticButton>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {

    [SupplyParameterFromForm]
    private ChangePasswordModel? Model { get; set; }

    private string? ErrorMessage { get; set; }

    private bool Success { get; set; }

    protected override void OnInitialized()
    {
        Model ??= new ChangePasswordModel();
    }

    private async Task HandleChangePassword()
    {
        ErrorMessage = null;
        Success = false;
        if (Model == null)
        {
            return;
        }

        var serviceId = int.TryParse(Model.ServiceId, out var id) ? id : 0;
        var (user, error) = await AccountService.SignInAsync(serviceId, Model.Email, Model.CurrentPassword);
        if (user == null)
        {
            ErrorMessage = error;
            return;
        }

        var result = await AccountService.ChangePasswordAsync(serviceId, Model.Email, Model.NewPassword);
        if (result)
        {
            Success = true;
        }
        else
        {
            ErrorMessage = "Failed to change password. Please try again.";
        }
    }

    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "Service ID is required.")]
        public string ServiceId { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Current password is required.")]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "New password is required.")]
        [MinLength(8, ErrorMessage = "New password must be at least 8 characters long.")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your new password.")]
        [Compare("NewPassword", ErrorMessage = "New password and confirmation do not match.")]
        public string ConfirmNewPassword { get; set; } = string.Empty;
    }

}