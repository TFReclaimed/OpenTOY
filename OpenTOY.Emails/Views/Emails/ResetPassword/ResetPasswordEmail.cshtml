@using OpenTOY.Emails.Views.Shared
@model OpenTOY.Emails.Views.Emails.ResetPassword.ResetPasswordViewModel

<mj-text font-weight="700" color="#3d4852" font-size="18px" padding-bottom="16px">
    Reset Your OpenTOY Password
</mj-text>

<mj-text color="#718096" font-size="16px" line-height="1.4">
    We received a request to reset the password for your OpenTOY account associated with the email @Model.Email and service @Model.ServiceName.
    If you made this request, please click the button below to reset your password.
</mj-text>

@await Html.PartialAsync("EmailButton", new EmailButtonViewModel("Reset Password", Model.ResetLink))

<mj-text color="#718096" font-size="16px" line-height="1.4">
    If you did not request a password reset, please ignore this email. Your password will remain unchanged.
</mj-text>

<mj-text color="#718096" font-size="16px" line-height="1.4">
    This link expires in @Model.ExpiresInMinutes minutes.
</mj-text>

<mj-text color="#718096" font-size="16px" line-height="1.4">
    Regards, <br/>The OpenTOY team
</mj-text>