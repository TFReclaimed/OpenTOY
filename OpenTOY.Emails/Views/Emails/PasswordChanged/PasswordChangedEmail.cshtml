@model OpenTOY.Emails.Views.Emails.PasswordChanged.PasswordChangedViewModel

<mj-text font-weight="700" color="#3d4852" font-size="18px" padding-bottom="16px">
    @Model.ServiceName Password Changed
</mj-text>

<mj-text color="#718096" font-size="16px" line-height="1.4">
    Hi @Model.Email,<br/><br/>
    This is a confirmation that the password for your account on @Model.ServiceName has just been changed.
</mj-text>

<mj-text color="#718096" font-size="16px" line-height="1.4">
    Regards, <br/>The OpenTOY team
</mj-text>